MERGE (n:Entity {id:"cohort:gse32062_holdout"}) SET n:PatientCohort, n.type="patient_cohort", n.name="GSE32062 external holdout (n=260, GPL6480) \u2014 fingerprint did NOT validate", n._stream="v3:artistry7_publications", n._source_kb="artistry7_platinum_window", n.source_file="data-room/datasets/artistry7-platinum-window/publications/11-artistry7-hgsoc-subgroup/data/validation_manifest.json", n.verbatim=["GSE32062 n=260: external validation NEGATIVE (logrank p=0.929)"], n.n_patients=260, n.platform="GPL6480", n.validation_holds=false;
MERGE (n:Entity {id:"governance_item:pub_spe_not_efficacy"}) SET n:GovernanceItem, n.type="governance_item", n.name="SPE gap-ratio is a FEASIBILITY pre-filter, NOT efficacy proof", n._stream="v3:artistry7_publications", n._source_kb="artistry7_platinum_window", n.source_file="artistry7_integration::governance (derived from manuscript RUO statements + limitation sections)", n.verbatim=["A PASS verdict means cytotoxic free plasma concentration is physically achievable at tolerated dose; it does NOT mean the drug is efficacious. A FAIL rules out a candidate on exposure grounds only. SPE must never be cited as evidence a drug works."], n.guardrail_text="A PASS verdict means cytotoxic free plasma concentration is physically achievable at tolerated dose; it does NOT mean the drug is efficacious. A FAIL rules out a candidate on exposure grounds only. SPE must never be cited as evidence a drug works.", n.scope=["capability:pub_spe_gate"];
MERGE (n:Entity {id:"governance_item:pub_hgsoc_prognostic_not_predictive"}) SET n:GovernanceItem, n.type="governance_item", n.name="HGSOC fingerprint is PROGNOSTIC, not PREDICTIVE", n._stream="v3:artistry7_publications", n._source_kb="artistry7_platinum_window", n.source_file="artistry7_integration::governance (derived from manuscript RUO statements + limitation sections)", n.verbatim=["HR=0.7208 describes survival under heterogeneous standard-of-care. It does NOT predict response to any specific therapy. Any patient-selection or treatment-assignment claim requires prospective, treatment-stratified validation on the intended endpoint. Never state the fingerprint 'predicts response' or 'selects patients for [drug]'."], n.guardrail_text="HR=0.7208 describes survival under heterogeneous standard-of-care. It does NOT predict response to any specific therapy. Any patient-selection or treatment-assignment claim requires prospective, treatment-stratified validation on the intended endpoint. Never state the fingerprint 'predicts response' or 'selects patients for [drug]'.", n.scope=["capability:pub_hgsoc_fingerprint"];
MERGE (n:Entity {id:"governance_item:pub_hgsoc_external_fails"}) SET n:GovernanceItem, n.type="governance_item", n.name="HGSOC fingerprint external validation on GSE32062 DID NOT HOLD", n._stream="v3:artistry7_publications", n._source_kb="artistry7_platinum_window", n.source_file="artistry7_integration::governance (derived from manuscript RUO statements + limitation sections)", n.verbatim=["GSE32062 tiered OS separation was non-significant (logrank p=0.929, validation_holds=false) using transferred discovery thresholds. The favorable-survival claim is a pooled-discovery finding awaiting successful external replication; do not present it as externally validated."], n.guardrail_text="GSE32062 tiered OS separation was non-significant (logrank p=0.929, validation_holds=false) using transferred discovery thresholds. The favorable-survival claim is a pooled-discovery finding awaiting successful external replication; do not present it as externally validated.", n.scope=["capability:pub_hgsoc_fingerprint"];
MERGE (n:Entity {id:"governance_item:pub_timing_internal_not_clinical"}) SET n:GovernanceItem, n.type="governance_item", n.name="Timing engine internal verification = CONSISTENCY, not clinical validity", n._stream="v3:artistry7_publications", n._source_kb="artistry7_platinum_window", n.source_file="artistry7_integration::governance (derived from manuscript RUO statements + limitation sections)", n.verbatim=["95.6% exact-day agreement confirms the engine reproduces a reference PFI derivation (algorithmic consistency). It is NOT evidence of clinical validity or outcome prediction. The ARIEL3 external comparison is equivalence-INCONCLUSIVE (TOST p=0.073, underpowered), NOT a positive equivalence result."], n.guardrail_text="95.6% exact-day agreement confirms the engine reproduces a reference PFI derivation (algorithmic consistency). It is NOT evidence of clinical validity or outcome prediction. The ARIEL3 external comparison is equivalence-INCONCLUSIVE (TOST p=0.073, underpowered), NOT a positive equivalence result.", n.scope=["capability:pub_timing_engine"];
MERGE (n:Entity {id:"governance_item:pub_ruo_all"}) SET n:GovernanceItem, n.type="governance_item", n.name="Publication-derived capabilities are Research Use Only (RUO)", n._stream="v3:artistry7_publications", n._source_kb="artistry7_platinum_window", n.source_file="artistry7_integration::governance (derived from manuscript RUO statements + limitation sections)", n.verbatim=["The HGSOC fingerprint and timing engine are computational/retrospective and RUO; they are not clinical decision support and do not predict individual patient outcomes. RUO is a disclosure of evidence status, not a refusal to state the (cited, reproduced) quantitative findings."], n.guardrail_text="The HGSOC fingerprint and timing engine are computational/retrospective and RUO; they are not clinical decision support and do not predict individual patient outcomes. RUO is a disclosure of evidence status, not a refusal to state the (cited, reproduced) quantitative findings.", n.scope=["capability:pub_hgsoc_fingerprint","capability:pub_timing_engine"];
MERGE (n:Entity {id:"governance_item:pub_no_tier_inflation"}) SET n:GovernanceItem, n.type="governance_item", n.name="No evidence-tier inflation across publication capabilities", n._stream="v3:artistry7_publications", n._source_kb="artistry7_platinum_window", n.source_file="artistry7_integration::governance (derived from manuscript RUO statements + limitation sections)", n.verbatim=["Internal verification != external validation. Descriptive/retrospective subgroup separation != out-of-sample prediction. A failing or inconclusive validation must travel with the capability. Ingested benchmark/trial figures with reproduced=false must be labeled as reported, not re-derived."], n.guardrail_text="Internal verification != external validation. Descriptive/retrospective subgroup separation != out-of-sample prediction. A failing or inconclusive validation must travel with the capability. Ingested benchmark/trial figures with reproduced=false must be labeled as reported, not re-derived.", n.scope=["capability:pub_spe_gate","capability:pub_hgsoc_fingerprint","capability:pub_timing_engine"];
