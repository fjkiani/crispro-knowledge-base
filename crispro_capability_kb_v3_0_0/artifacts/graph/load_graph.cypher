// ============================================================================
// CrisPRO Knowledge Graph — PORTABLE LOADER (self-contained, APOC-free)
// Recreates the full graph on any Neo4j 5.x instance.
// Generated from live graph: 617 nodes / 655 relationships
// Usage:  cat load_graph.cypher | cypher-shell -u neo4j -p <pw>
//    or:  :source load_graph.cypher   (in Neo4j Browser)
// ============================================================================

// ---- 0. Clean slate (comment out to append instead) ----
MATCH (n) DETACH DELETE n;

// ---- 1. Uniqueness constraint on id (also creates an index) ----
CREATE CONSTRAINT kb_id_unique IF NOT EXISTS FOR (n:KBNode) REQUIRE n.id IS UNIQUE;

// ---- 2. Nodes (617) ----
