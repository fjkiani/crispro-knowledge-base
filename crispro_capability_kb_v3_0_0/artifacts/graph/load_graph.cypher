CREATE (:Entity:BriefProgramDeep:KBNode {product_layer: 'interception', cross_refs: [], mint_planner: 'p2', stream: 'v3:audit_upgrade', attributes_json: '{}', name: 'NSCLC brain metastasis (BrM)', id: 'brief_program:brief-1', type: 'brief_program_deep', verbatim: ['{"id": "BRIEF-1", "axis": "ZEB1 \\u2192 ITGAV (synthetic lethality)", "evidence_tier": "CRISPR_VALIDATED", "deal_ready": true, "delta": -0.7184, "fdr": 0.001203, "status": "DEAL_READY", "indication": "NSCLC brain metastasis (BrM)", "what_zeb1_is": "ZEB1 (Zinc finger E-box binding homeobox 1) is a master regulator of epithelial-mesenchymal transition (EMT). In NSCLC/BrM, ZEB1-high tumors have undergone EMT \\u2014 they are more invasive, more metastatic, and more resistant to chemotherapy. ZEB1-high is a marker of aggressive disease.", "what_itgav_is": "ITGAV (Integrin alpha-V) is a cell surface receptor that mediates cell adhesion to the extracellular matrix. In ZEB1-high cells, ITGAV becomes essential for survival \\u2014 ZEB1-high cells depend on integrin signaling for anoikis resistance an'], source_file: 'crispro-knowledge-base/crispro_kg_v2/kg_modules/program_brief_sl.json', json_pointer: '/programs/0'});
CREATE (:Entity:BriefProgramDeep:KBNode {product_layer: 'interception', cross_refs: ['gov:brief_2_hypothesis'], mint_planner: 'p2', stream: 'v3:audit_upgrade', attributes_json: '{}', name: 'NSCLC brain metastasis (BrM)', id: 'brief_program:brief-2', type: 'brief_program_deep', verbatim: ['{"id": "BRIEF-2", "axis": "PTEN-null \\u2192 ITGAV", "evidence_tier": "COMPUTATIONAL_HYPOTHESIS", "deal_ready": false, "status": "VALIDATION_REQUIRED", "indication": "NSCLC brain metastasis (BrM)", "rationale": "PTEN-null cells lose PI3K/AKT regulation and may become dependent on integrin signaling (ITGAV) for survival \\u2014 similar to ZEB1-high cells.", "depmap_result": "DepMap NULL across all 3 proxies \\u2014 ITGAV is NOT more essential in PTEN-null cells than PTEN-intact cells in the DepMap data.", "mandatory_disclosure": "BRIEF-2 (PTEN-null\\u2192ITGAV) is a COMPUTATIONAL HYPOTHESIS. DepMap shows NULL essentiality across all 3 proxies. Not CRISPR-validated. Requires experimental validation before any licensing discussion. Must be disclosed in every context where BRIEF-2 appears.", "sour'], source_file: 'crispro-knowledge-base/crispro_kg_v2/kg_modules/program_brief_sl.json', json_pointer: '/programs/3'});
CREATE (:Entity:BriefProgramDeep:KBNode {product_layer: 'interception', cross_refs: [], mint_planner: 'p2', stream: 'v3:audit_upgrade', attributes_json: '{}', name: 'NSCLC brain metastasis (BrM)', id: 'brief_program:brief-3', type: 'brief_program_deep', verbatim: ['{"id": "BRIEF-3", "axis": "ZEB1-high + PD-1 blockade combination", "evidence_tier": "MECHANISTICALLY_GROUNDED", "deal_ready": "conditional", "status": "CONDITIONAL_ONE_GAP", "indication": "NSCLC brain metastasis (BrM)", "rationale": "ZEB1-high tumors upregulate PD-L1 expression (ZEB1 directly transcribes PD-L1). ZEB1-high + PD-1 blockade is mechanistically grounded \\u2014 ZEB1-high tumors should be more responsive to checkpoint blockade.", "correlation_result": "GSE271259 (n=34): r=0.050, p=0.780 \\u2014 statistically INSIGNIFICANT. The correlation between ZEB1 expression and PD-1 response is not supported by this dataset.", "mandatory_disclosure": "BRIEF-3 correlation r=0.050, p=0.780 is statistically insignificant. BRIEF-3 is MECHANISTICALLY_GROUNDED, not CRISPR_VALIDATED. The combination'], source_file: 'crispro-knowledge-base/crispro_kg_v2/kg_modules/program_brief_sl.json', json_pointer: '/programs/2'});
CREATE (:Entity:BriefProgramDeep:KBNode {product_layer: 'interception', cross_refs: [], mint_planner: 'p2', stream: 'v3:audit_upgrade', attributes_json: '{}', name: 'NSCLC brain metastasis (BrM)', id: 'brief_program:brief-4', type: 'brief_program_deep', verbatim: ['{"id": "BRIEF-4", "axis": "SPP1 \\u2192 NRF2 (synthetic lethality)", "evidence_tier": "CRISPR_VALIDATED", "deal_ready": false, "delta": -0.7326, "fdr": 8e-06, "status": "COMPUTATIONAL_LEAD", "indication": "NSCLC brain metastasis (BrM)", "what_spp1_is": "SPP1 (Secreted Phosphoprotein 1, also known as Osteopontin) is a secreted glycoprotein that promotes tumor invasion, metastasis, and immune evasion. SPP1-high tumors have an immunosuppressive TME \\u2014 SPP1 recruits MDSCs and promotes M2 macrophage polarization.", "what_nrf2_is": "NRF2 (Nuclear factor erythroid 2-related factor 2) is a transcription factor that regulates the antioxidant response. In SPP1-high cells, NRF2 becomes essential for managing oxidative stress \\u2014 SPP1-high cells generate more reactive oxygen species (ROS) and de'], source_file: 'crispro-knowledge-base/crispro_kg_v2/kg_modules/program_brief_sl.json', json_pointer: '/programs/1'});
CREATE (:Entity:CalibrationProof:KBNode {product_layer: 'portfolio', cross_refs: [], mint_planner: 'p3', stream: 'v3:audit_upgrade', attributes_json: '{}', name: 'cbis_ddsm_logreg_v1_metrics', id: 'calibration_proof:cbis_ddsm_logreg_v1_metrics', type: 'calibration_proof', verbatim: ['{"dataset": {"name": "CBIS-DDSM_1024", "source": "https://huggingface.co/datasets/dbaek111/CBIS-DDSM_1024", "hf_zip_sha256": "123239b7f68c3a309b33784aff0a7f91ff9200edc5a2f76c4507ce96cc7c0e53", "n_total": 3086, "n_train": 2445, "n_test": 641, "n_train_positive": 1098, "n_train_negative": 1347, "n_test_positive": 260, "n_test_negative": 381}, "features": {"source_model": "google/medsiglip-448", "mod'], source_file: 'scientist-monai-moat/docs/proofs/cbis_ddsm_logreg_v1_metrics.json', json_pointer: '/'});
CREATE (:Entity:Capability:KBNode {cap_code: 'CAP_01', product_layer: 'biology_intelligence', name: '8D Patient Vector Construction', cannot_do: 'Cannot construct patient vector without molecular profiling data. Cannot infer axis values from clinical features alone.', id: 'capability:CAP_01', source: 'mechanism_fit_ranker.py; 8d_verified_claims.md V1', type: 'capability', what_it_does: 'Constructs an 8-dimensional patient biology vector from molecular profiling data (NGS, IHC, ctDNA, imaging)', full_json: '{"id": "CAP-01", "name": "8D Patient Vector Construction", "what_it_does": "Constructs an 8-dimensional patient biology vector from molecular profiling data (NGS, IHC, ctDNA, imaging)", "inputs": ["NGS panel (KRAS, NRAS, BRAF, ATM, BRCA1/2, PTEN, PIK3CA, CCNE1)", "IHC (PD-L1, CEACAM5, CD8+, FOXP3)", "ctDNA (pTMB, VAF)", "Imaging (liver metastasis status)"], "output": "8D patient vector p = [ddr, mapk, pi3k, vegf, her2, io, efflux, rss] ∈ [0,1]⁸", "evidence_tier": "COMPUTED", "validated_on": ["BreAK CRC-001 (p_vector_locked.json)", "LATIFY (responder 0.8936 vs non-responder 0.6295)"], "cannot_do": "Cannot construct patient vector without molecular profiling data. Cannot infer axis values from clinical features alone.", "source": "mechanism_fit_ranker.py; 8d_verified_claims.md V1"}', evidence_tier: 'COMPUTED'});
CREATE (:Entity:Capability:KBNode {cap_code: 'CAP_02', formula_status: 'PATH A — LOCKED 2026-04-28', product_layer: 'insilico_trials', name: 'Mechanism Fit Engine (PATH A)', formula: 'fit = clip((p·t) / ‖t‖₂, 0, 1)', cannot_do: 'Cannot compute fit without both patient vector and trial vector. PATH B formula is PROHIBITED.', id: 'capability:CAP_02', source: 'mechanism_fit_ranker.py; 8d_verified_claims.md V2–V5', type: 'capability', what_it_does: 'Computes fit = clip((p·t)/‖t‖₂, 0, 1) between patient vector p and trial vector t. Returns fit score, axis contributions, and fit label.', full_json: '{"id": "CAP-02", "name": "Mechanism Fit Engine (PATH A)", "what_it_does": "Computes fit = clip((p·t)/‖t‖₂, 0, 1) between patient vector p and trial vector t. Returns fit score, axis contributions, and fit label.", "formula": "fit = clip((p·t) / ‖t‖₂, 0, 1)", "formula_status": "PATH A — LOCKED 2026-04-28", "output_labels": {"0.0-0.4": "LOW", "0.4-0.6": "MODERATE", "0.6-0.8": "MODERATE-HIGH", "0.8-1.0": "HIGH"}, "evidence_tier": "COMPUTED", "validated_on": ["BreAK CRC-001: fit=0.7375 (MODERATE-HIGH)", "LATIFY: responder 0.8936 vs non-responder 0.6295"], "cannot_do": "Cannot compute fit without both patient vector and trial vector. PATH B formula is PROHIBITED.", "source": "mechanism_fit_ranker.py; 8d_verified_claims.md V2–V5"}', evidence_tier: 'COMPUTED'});
CREATE (:Entity:Capability:KBNode {cap_code: 'CAP_03', product_layer: 'insilico_trials', name: 'Trial Vector Library', cannot_do: 'Cannot generate trial vectors for trials not in the corpus without manual curation.', id: 'capability:CAP_03', source: 'block4_8d_path_matrix_v2.csv; program_asset_*.json files', type: 'capability', what_it_does: 'Maintains a curated library of 8D trial mechanism vectors for all programs in the CrisPRO corpus (22+ trials)', full_json: '{"id": "CAP-03", "name": "Trial Vector Library", "what_it_does": "Maintains a curated library of 8D trial mechanism vectors for all programs in the CrisPRO corpus (22+ trials)", "trial_count": 22, "evidence_tier": "COMPUTED", "validated_on": ["Block4 8D path matrix v2 (8 trials)", "IO Core (7 trials)", "IO Appendix (15 trials)", "CEACAM5 (5 trials)", "ATR/DDR (5 trials)"], "cannot_do": "Cannot generate trial vectors for trials not in the corpus without manual curation.", "source": "block4_8d_path_matrix_v2.csv; program_asset_*.json files"}', evidence_tier: 'COMPUTED'});
CREATE (:Entity:Capability:KBNode {cap_code: 'CAP_04', product_layer: 'interception', name: 'Target-Lock (Metastasis Driver Identification)', cannot_do: 'CEACAM5 is NOT in the 38-gene panel — Target-Lock run not executed for CEACAM5. GBM ZEB1 is PERMANENTLY CLOSED.', id: 'capability:CAP_04', source: 'ceacam5_cap_map.md; gate_arch_v2.md; program_asset_gbm_escapemap.json', type: 'capability', what_it_does: 'Identifies genuine metastasis drivers using a composite algorithm: Evo2-7B (evolutionary constraint) + Enformer (chromatin accessibility) + AlphaFold 3 (structural confidence). Composite threshold ≥0.35 = genuine driver.', full_json: '{"id": "CAP-04", "name": "Target-Lock (Metastasis Driver Identification)", "what_it_does": "Identifies genuine metastasis drivers using a composite algorithm: Evo2-7B (evolutionary constraint) + Enformer (chromatin accessibility) + AlphaFold 3 (structural confidence). Composite threshold ≥0.35 = genuine driver.", "algorithm": {"evo2_7b": "Evolutionary constraint — likelihood of WT vs mutant under evolutionary selection. High constraint = gene is under purifying selection = likely essential.", "enformer": "Chromatin accessibility and gene regulatory activity — predicts ATAC-seq/ChIP-seq from DNA sequence. High activity = gene is actively transcribed in the tumor.", "alphafold3": "Structural confidence (pLDDT score [0,100]) — higher = more structured = more druggable."}, "evidence_tier": "COMPUTED", "validated_on": ["OV ZEB1: HR=1.4803 (continuous Cox, bevacizumab arm OS)", "CEACAM5 IHC ↔ cCEA Spearman ρ=0.43 (n=92)"], "cannot_do": "CEACAM5 is NOT in the 38-gene panel — Target-Lock run not executed for CEACAM5. GBM ZEB1 is PERMANENTLY CLOSED.", "source": "ceacam5_cap_map.md; gate_arch_v2.md; program_asset_gbm_escapemap.json"}', evidence_tier: 'COMPUTED'});
CREATE (:Entity:Capability:KBNode {cap_code: 'CAP_05', product_layer: 'biology_intelligence', name: 'SL Therapy Bridge v3', cannot_do: 'TP53 and genes not in SL_THERAPY_MAP return no sl_indicated_drugs. BRIEF-2 (PTEN-null→ITGAV) is NOT in SL_THERAPY_MAP.', id: 'capability:CAP_05', source: 'crispro_v3_sl_bridge_audit.md; PR #5', type: 'capability', what_it_does: 'Maps patient SL vulnerabilities to actionable drugs with ALLOW/WARN/DISALLOW policy overlay. 20/20 tests PASS.', full_json: '{"id": "CAP-05", "name": "SL Therapy Bridge v3", "what_it_does": "Maps patient SL vulnerabilities to actionable drugs with ALLOW/WARN/DISALLOW policy overlay. 20/20 tests PASS.", "evidence_tier": "COMPUTED", "validated_on": ["20/20 unit tests PASS (crispro_v3_sl_bridge_audit.md)"], "cannot_do": "TP53 and genes not in SL_THERAPY_MAP return no sl_indicated_drugs. BRIEF-2 (PTEN-null→ITGAV) is NOT in SL_THERAPY_MAP.", "source": "crispro_v3_sl_bridge_audit.md; PR #5"}', evidence_tier: 'COMPUTED'});
CREATE (:Entity:Capability:KBNode {cap_code: 'CAP_05_bridge_detail', product_layer: 'biology_intelligence', name: 'SL Therapy Bridge v3', id: 'capability:CAP_05_bridge_detail', source: 'crispro_v3_sl_bridge_audit.md; 20/20 tests PASS', type: 'capability', what_it_does: 'The SL Therapy Bridge sits between the SL vulnerability detection layer and the therapy fit scoring layer. It takes a patient\'s SL vulnerabilities (broken pathways, SL gene pairs) and maps them to actionable drugs with a policy overlay (ALLOW/WARN/DISALLOW).', full_json: '{"capability_id": "CAP-05", "name": "SL Therapy Bridge v3", "evidence_tier": "COMPUTED", "code_location": "crispro-backend-v2/api/services/sl_therapy_bridge/", "test_status": "20/20 tests PASS", "pr": "https://github.com/fjkiani/crispro-backend-v2/pull/5", "what_it_does": "The SL Therapy Bridge sits between the SL vulnerability detection layer and the therapy fit scoring layer. It takes a patient\'s SL vulnerabilities (broken pathways, SL gene pairs) and maps them to actionable drugs with a policy overlay (ALLOW/WARN/DISALLOW).", "architecture": {"before_v3": "Two disconnected layers: (1) SL layer identified vulnerabilities but returned a flat list of drug names with no mechanism context; (2) Therapy Fit layer scored drugs but had no awareness of which drugs were SL-indicated vs. mechanism-aligned vs. false-positive traps.", "v3_bridge": "Additive bridge layer that produces a sl_therapy_bridge payload in the /bundle response. Does NOT modify existing keys or scores — purely additive.", "files": {"models.py": "Dataclasses: SLIndicatedDrug, PolicyOverlay, GapSummary, SLTherapyBridgeResult", "policy_engine.py": "SLPolicyEngine + SL_THERAPY_MAP (curated, versioned, non-ML)", "bridge.py": "SLTherapyBridge.compute() — orchestrates vulnerability detection, policy evaluation, gap summary"}}, "allow_warn_disallow_logic": {"ALLOW": "Drug is SL-indicated for this vulnerability AND has clinical validation. Safe to recommend. Example: olaparib for BRCA2-mut (ALLOW — FDA-approved, validated SL).", "WARN": "Drug is SL-indicated but has a known resistance mechanism or safety concern. Recommend with caution. Example: PTEN-null → mTOR inhibitors (WARN — PTEN-loss creates PI3K dependency but mTOR inhibitors have limited single-agent activity in CRC).", "DISALLOW": "Drug is NOT SL-indicated for this vulnerability — recommending it would be a false positive. Example: KRAS-mut → EGFR TKIs (DISALLOW — KRAS mutation is a contraindication for EGFR TKI benefit).", "PRECLINICAL_ONLY": "Drug is SL-indicated but only has preclinical evidence. Not ready for clinical recommendation. Example: SMARCA4-mut → FHD-909 (ALLOW, PRECLINICAL_ONLY)."}, "sl_therapy_map": {"BRCA2_mut": {"drugs": ["olaparib", "niraparib", "rucaparib"], "tier": "ALLOW", "evidence": "FDA-approved, validated SL"}, "BRCA1_mut": {"drugs": ["olaparib", "niraparib", "rucaparib"], "tier": "ALLOW", "evidence": "FDA-approved, validated SL"}, "ATM_mut": {"drugs": ["ceralasertib", "berzosertib"], "tier": "ALLOW", "evidence": "Clinical validation in ATM-mut tumors"}, "ARID1A_mut": {"drugs": ["tazemetostat"], "tier": "ALLOW", "evidence": "EZH2 SL with ARID1A — clinical validation"}, "SMARCA4_mut": {"drugs": ["FHD-909"], "tier": "ALLOW_PRECLINICAL_ONLY", "evidence": "Preclinical only"}, "CCNE1_AMP": {"drugs": ["CDK2 inhibitors"], "tier": "ALLOW", "evidence": "CDK2 dependency in CCNE1-amp tumors"}, "KRAS_mut": {"drugs": ["EGFR TKIs"], "tier": "DISALLOW", "evidence": "KRAS mutation is a contraindication for EGFR TKI benefit"}, "PTEN_null": {"drugs": ["mTOR inhibitors", "PI3K inhibitors"], "tier": "WARN", "evidence": "Limited single-agent activity; combination strategies preferred"}}, "gap_summary_output": {"description": "The GapSummary identifies drugs that are SL-indicated but blocked by the policy overlay", "fields": {"top_fit_blocked_count": "Number of top-ranked drugs that are DISALLOW or WARN", "best_actionable_rank": "Rank of the highest-ranked ALLOW drug", "gap_description": "Plain-language explanation of why top drugs are blocked"}}, "what_it_cannot_do": "TP53 and other genes not in SL_THERAPY_MAP return no sl_indicated_drugs — no crash, no hallucination. PTEN-null → ITGAV (BRIEF-2) is COMPUTATIONAL_HYPOTHESIS — not in SL_THERAPY_MAP.", "source": "crispro_v3_sl_bridge_audit.md; 20/20 tests PASS"}', evidence_tier: 'COMPUTED'});
CREATE (:Entity:Capability:KBNode {cap_code: 'CAP_06', product_layer: 'biology_intelligence', name: 'BRIEF Program Asset Generation', cannot_do: 'BRIEF-2 (PTEN-null→ITGAV) is COMPUTATIONAL HYPOTHESIS — DepMap NULL. Must disclose in every context.', id: 'capability:CAP_06', source: 'crispro_ip_valuation_glb_v1.mdc; crispro_master_pipeline.json ip_estate', type: 'capability', what_it_does: 'Identifies synthetic lethality pairs from CRISPR functional genomics (DepMap), computes delta scores, applies FDR correction, and validates with targeted CRISPR experiments.', full_json: '{"id": "CAP-06", "name": "BRIEF Program Asset Generation", "what_it_does": "Identifies synthetic lethality pairs from CRISPR functional genomics (DepMap), computes delta scores, applies FDR correction, and validates with targeted CRISPR experiments.", "evidence_tier": "CRISPR_VALIDATED (BRIEF-1, BRIEF-4) / COMPUTATIONAL_HYPOTHESIS (BRIEF-2) / MECHANISTICALLY_GROUNDED (BRIEF-3)", "validated_on": ["BRIEF-1: ZEB1→ITGAV, delta=−0.7184, FDR=0.001203, CRISPR_VALIDATED", "BRIEF-4: SPP1→NRF2, delta=−0.7326, FDR=8×10⁻⁶, CRISPR_VALIDATED"], "cannot_do": "BRIEF-2 (PTEN-null→ITGAV) is COMPUTATIONAL HYPOTHESIS — DepMap NULL. Must disclose in every context.", "source": "crispro_ip_valuation_glb_v1.mdc; crispro_master_pipeline.json ip_estate"}', evidence_tier: 'CRISPR_VALIDATED (BRIEF-1, BRIEF-4) / COMPUTATIONAL_HYPOTHESIS (BRIEF-2) / MECHANISTICALLY_GROUNDED (BRIEF-3)'});
CREATE (:Entity:Capability:KBNode {cap_code: 'CAP_07', product_layer: 'biology_intelligence', name: 'EscapeMap (Bevacizumab Biomarker Stratification)', cannot_do: 'GBM ZEB1 is PERMANENTLY CLOSED — 3 datasets all null/contradicted. Arm interaction p=0.246 — ZEB1 is PROGNOSTIC, NOT ARM-SPECIFIC.', id: 'capability:CAP_07', source: 'ovarian_io_verified_metrics.md; program_asset_gbm_escapemap.json', type: 'capability', what_it_does: 'Characterizes ZEB1 as a prognostic biomarker in the bevacizumab arm using Cox regression, median-split, and tertile analyses.', full_json: '{"id": "CAP-07", "name": "EscapeMap (Bevacizumab Biomarker Stratification)", "what_it_does": "Characterizes ZEB1 as a prognostic biomarker in the bevacizumab arm using Cox regression, median-split, and tertile analyses.", "evidence_tier": "COMPUTED", "validated_on": ["OV ZEB1 continuous Cox: HR=1.4803 (95% CI [1.1188, 1.9586], p=0.006042)", "OV ZEB1 median split: HR=2.500 (FDR=0.0499)", "M2 stratum calibration: GEO 74.0% vs published 73.9%"], "cannot_do": "GBM ZEB1 is PERMANENTLY CLOSED — 3 datasets all null/contradicted. Arm interaction p=0.246 — ZEB1 is PROGNOSTIC, NOT ARM-SPECIFIC.", "source": "ovarian_io_verified_metrics.md; program_asset_gbm_escapemap.json"}', evidence_tier: 'COMPUTED'});
CREATE (:Entity:Capability:KBNode {cap_code: 'CAP_07_escapemap_detail', product_layer: 'biology_intelligence', name: 'EscapeMap — Bevacizumab Biomarker Stratification (Ovarian)', id: 'capability:CAP_07_escapemap_detail', type: 'capability', full_json: '{"capability_id": "CAP-07", "name": "EscapeMap — Bevacizumab Biomarker Stratification (Ovarian)", "evidence_tier": "COMPUTED", "what_escapemap_is": "EscapeMap is CrisPRO\'s analysis of ZEB1 as a prognostic biomarker in the bevacizumab arm of ovarian cancer trials. It uses Cox regression, median-split, and tertile analyses to characterize the ZEB1-bevacizumab relationship.", "methodology": {"dataset": "GOG-0218 (bevacizumab arm) — ovarian cancer Phase III trial", "continuous_cox_model": {"description": "Cox proportional hazards model with ZEB1 expression as a continuous variable", "result": "HR=1.4803 (95% CI [1.1188, 1.9586], p=0.006042, c-stat=0.6444) — bevacizumab arm OS", "interpretation": "Each unit increase in ZEB1 expression is associated with a 48% increase in the hazard of death in the bevacizumab arm. ZEB1-high patients have worse OS on bevacizumab."}, "multivariable_cox": {"result": "HR=1.5247 (95% CI [1.1256, 2.0652], p=0.006447) — adjusted for covariates", "interpretation": "ZEB1 is an independent prognostic factor after adjusting for other clinical variables."}, "arm_interaction": {"result": "HR=1.243, p=0.245949", "interpretation": "PROGNOSTIC, NOT ARM-SPECIFIC. The arm interaction p=0.246 means ZEB1 is prognostic (predicts OS regardless of treatment) but NOT predictive of bevacizumab benefit specifically. ZEB1-high patients do worse on bevacizumab, but they also do worse on chemotherapy alone.", "mandatory_wording": "ZEB1 is a prognostic marker in the bevacizumab arm, not a predictive marker of bevacizumab benefit. The arm interaction is not statistically significant (p=0.246)."}, "median_split": {"result": "HR=2.500 (95% CI [1.322, 4.727], log-rank p=0.0036, FDR=0.0499) — bevacizumab arm OS", "interpretation": "ZEB1-high patients (above median) have 2.5× higher hazard of death than ZEB1-low patients in the bevacizumab arm."}, "tertile_analysis": {"result": "T3 vs T1: HR=2.4932 (95% CI [1.1767, 5.2824], p=0.017093)", "interpretation": "Top tertile ZEB1 vs bottom tertile: 2.5× higher hazard of death."}, "hif1a_result": {"result": "HR=2.245 (95% CI [1.172, 4.300], p=0.0147) — bevacizumab arm OS", "interpretation": "HIF1A is also prognostic in the bevacizumab arm — PLATFORM_COMPRESSION signal (multiple EMT/angiogenesis markers are prognostic)."}, "m2_stratum": {"result": "M2 beneficial median OS: 34.4 months (CI 32.7–38.8), p=9.52×10⁻⁵", "mandatory_wording": "Preparatory M2-bevacizumab biomarker panel for downstream descriptive and conditioning analyses — not a validated prognostic signature until dbGaP-linked patient-level outcomes are available. (LOCKED 2026-05-12)"}}, "gbm_permanently_closed": {"status": "PERMANENTLY CLOSED", "reason": "Three datasets all null or contradicted:", "datasets": [{"dataset": "GLASS", "result": "delta=−0.34, p=0.000184, d=−0.31 — ZEB1 DECREASES in recurrent GBM (opposite of escape hypothesis)"}, {"dataset": "GSE222515", "result": "delta=−0.431, p=0.0334 — ZEB1 DECREASES in recurrent GBM"}, {"dataset": "GSE174554 snRNA-seq", "result": "delta=−0.076, p=0.742, d=−0.070 — NULL (not significant)"}], "operational_meaning": "Do not apply EscapeMap to GBM. Do not reopen without new evidence. GBM ZEB1 is not an escape marker — it decreases in recurrent GBM, which is the opposite of the escape hypothesis.", "source": "program_asset_gbm_escapemap.json; crispro_master_pipeline.json programs[GBM_ESCAPEMAP]"}, "what_crispro_proved": ["OV ZEB1 continuous Cox: HR=1.4803 (95% CI [1.1188, 1.9586], p=0.006042) — bevacizumab arm OS", "OV ZEB1 multivariable Cox: HR=1.5247 (95% CI [1.1256, 2.0652], p=0.006447)", "OV ZEB1 arm interaction: HR=1.243, p=0.246 — PROGNOSTIC, NOT ARM-SPECIFIC", "OV ZEB1 median split: HR=2.500 (95% CI [1.322, 4.727], FDR=0.0499)", "OV HIF1A: HR=2.245 (95% CI [1.172, 4.300], p=0.0147) — PLATFORM_COMPRESSION", "M2 stratum calibration: GEO 74.0% vs published 73.9% (within 0.1%)"]}', evidence_tier: 'COMPUTED'});
CREATE (:Entity:Capability:KBNode {cap_code: 'CAP_08', product_layer: 'insilico_trials', name: 'Two-Gate Patient Selection Framework', cannot_do: 'Gate 1 fraction (28%) is OPEN_ASSUMPTION OA-08 — not validated in prospective data.', id: 'capability:CAP_08', source: 'ceacam5_cap_map.md; gate_arch_v2.md; SANOFI_SOURCE_OF_TRUTH.md', type: 'capability', what_it_does: 'Implements a two-gate patient selection framework for CEACAM5-targeted therapies: Gate 1 = IHC ≥80% (~28% of MSS mCRC); Gate 2 = IO permissiveness (pTMB ≥28 OR Immunoscore-IC high OR CD8+ TIL density high).', full_json: '{"id": "CAP-08", "name": "Two-Gate Patient Selection Framework", "what_it_does": "Implements a two-gate patient selection framework for CEACAM5-targeted therapies: Gate 1 = IHC ≥80% (~28% of MSS mCRC); Gate 2 = IO permissiveness (pTMB ≥28 OR Immunoscore-IC high OR CD8+ TIL density high).", "evidence_tier": "COMPUTED", "validated_on": ["CARMEN-LC03: IHC ≥80% OS HR=0.71 (post-hoc) vs IHC 50–79% PFS HR=1.38 (harmful)", "CO.26: pTMB ≥28 OS HR=0.34 (90% CI 0.18–0.63)"], "cannot_do": "Gate 1 fraction (28%) is OPEN_ASSUMPTION OA-08 — not validated in prospective data.", "source": "ceacam5_cap_map.md; gate_arch_v2.md; SANOFI_SOURCE_OF_TRUTH.md"}', evidence_tier: 'COMPUTED'});
CREATE (:Entity:Capability:KBNode {cap_code: 'CAP_09', product_layer: 'insilico_trials', name: 'Vector-Scalpel Biomarker Ranking', cannot_do: 'Ranking is specific to the CEACAM5 program — not generalizable to other programs without re-running.', id: 'capability:CAP_09', source: 'ceacam5_cap_map.md; gate_arch_v2.md', type: 'capability', what_it_does: 'Ranks biomarkers by their discriminative power for patient selection using the Vector-Scalpel algorithm.', full_json: '{"id": "CAP-09", "name": "Vector-Scalpel Biomarker Ranking", "what_it_does": "Ranks biomarkers by their discriminative power for patient selection using the Vector-Scalpel algorithm.", "evidence_tier": "COMPUTED", "validated_on": ["CEACAM5 ranking: cCEA (27/33) > pTMB (23/33) > IHC (20/33) > Immunoscore (19/33) > DetermaIO (15/33)"], "cannot_do": "Ranking is specific to the CEACAM5 program — not generalizable to other programs without re-running.", "source": "ceacam5_cap_map.md; gate_arch_v2.md"}', evidence_tier: 'COMPUTED'});
CREATE (:Entity:Capability:KBNode {cap_code: 'CAP_10', product_layer: 'tumor_board', name: 'Holistic Score Engine', formula: 'holistic = 0.4×mechanism_fit + 0.3×eligibility + 0.15×pgx_safety + 0.15×resistance_risk', cannot_do: 'Cannot compute holistic score without all four component scores.', id: 'capability:CAP_10', source: 'crispro-backend-v3/layer1_engines/holistic_score/models.py (VC-15)', type: 'capability', what_it_does: 'Combines mechanism fit (40%), eligibility (30%), pharmacogenomic safety (15%), and resistance risk (15%) into a single holistic score.', full_json: '{"id": "CAP-10", "name": "Holistic Score Engine", "what_it_does": "Combines mechanism fit (40%), eligibility (30%), pharmacogenomic safety (15%), and resistance risk (15%) into a single holistic score.", "formula": "holistic = 0.4×mechanism_fit + 0.3×eligibility + 0.15×pgx_safety + 0.15×resistance_risk", "evidence_tier": "COMPUTED", "validated_on": ["VC-15 — verified claim from crispro-backend-v3/layer1_engines/holistic_score/models.py"], "cannot_do": "Cannot compute holistic score without all four component scores.", "source": "crispro-backend-v3/layer1_engines/holistic_score/models.py (VC-15)"}', evidence_tier: 'COMPUTED'});
